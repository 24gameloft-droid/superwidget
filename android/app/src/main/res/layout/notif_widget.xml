<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/notif_root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#CC1E1E2E" android:padding="8dp">
    <TextView android:id="@+id/notif_title"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:textColor="#CDD6F4" android:textSize="13sp" android:textStyle="bold"
        android:paddingBottom="4dp" android:text="Notifications"
        android:singleLine="true" android:ellipsize="end"/>
    <LinearLayout android:id="@+id/row1" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingBottom="2dp" android:visibility="gone">
        <ImageView android:id="@+id/icon1" android:layout_width="20dp" android:layout_height="20dp"
            android:scaleType="fitCenter" android:layout_marginEnd="5dp" android:flexShrink="0"/>
        <TextView android:id="@+id/text1" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="10sp" android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
    <View android:id="@+id/div1" android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row2" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="2dp" android:paddingBottom="2dp" android:visibility="gone">
        <ImageView android:id="@+id/icon2" android:layout_width="20dp" android:layout_height="20dp"
            android:scaleType="fitCenter" android:layout_marginEnd="5dp"/>
        <TextView android:id="@+id/text2" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="10sp" android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
    <View android:id="@+id/div2" android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row3" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="2dp" android:paddingBottom="2dp" android:visibility="gone">
        <ImageView android:id="@+id/icon3" android:layout_width="20dp" android:layout_height="20dp"
            android:scaleType="fitCenter" android:layout_marginEnd="5dp"/>
        <TextView android:id="@+id/text3" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="10sp" android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
    <View android:id="@+id/div3" android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row4" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="2dp" android:paddingBottom="2dp" android:visibility="gone">
        <ImageView android:id="@+id/icon4" android:layout_width="20dp" android:layout_height="20dp"
            android:scaleType="fitCenter" android:layout_marginEnd="5dp"/>
        <TextView android:id="@+id/text4" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="10sp" android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
    <View android:id="@+id/div4" android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#33FFFFFF" android:visibility="gone"/>
    <LinearLayout android:id="@+id/row5" android:layout_width="match_parent"
        android:layout_height="0dp" android:layout_weight="1"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingTop="2dp" android:visibility="gone">
        <ImageView android:id="@+id/icon5" android:layout_width="20dp" android:layout_height="20dp"
            android:scaleType="fitCenter" android:layout_marginEnd="5dp"/>
        <TextView android:id="@+id/text5" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:textColor="#CDD6F4" android:textSize="10sp" android:maxLines="2"
            android:ellipsize="end"/>
    </LinearLayout>
</LinearLayout>
