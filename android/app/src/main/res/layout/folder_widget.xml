<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/folder_root"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#E60F0F0F">
    <GridView android:id="@+id/folder_grid"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:numColumns="auto_fit" android:columnWidth="70dp"
        android:verticalSpacing="15dp" android:horizontalSpacing="5dp"
        android:stretchMode="columnWidth" android:gravity="center"
        android:padding="10dp" android:clipToPadding="false"
        android:scrollbars="none" android:overScrollMode="never"/>
</FrameLayout>
